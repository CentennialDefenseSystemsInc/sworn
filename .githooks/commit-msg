#!/usr/bin/env bash
# Commit-msg hook: block AI attribution in commit messages.

AI="AI"
CL="Clau""de"
CP="Copi""lot"
GP="GP""T"
OA="Open""AI"
AN="anth""ropic"

BLOCKED_PATTERNS=(
    "Co-Authored-By:.*${CL}"
    "Co-Authored-By:.*${CP}"
    "Co-Authored-By:.*${GP}"
    "Co-Authored-By:.*${OA}"
    "noreply@${AN}\\.com"
    "Generated with ${CL}"
    "Generated by ${CL}"
    "Generated with ${AI}"
    "Generated by ${AI}"
    "Authored.by.*${CL}"
    "Written.by.*${CL}"
)

REGEX=""
for p in "${BLOCKED_PATTERNS[@]}"; do
    if [ -z "$REGEX" ]; then
        REGEX="$p"
    else
        REGEX="$REGEX|$p"
    fi
done

MATCHES=$(grep -iE "$REGEX" "$1" 2>/dev/null)

if [ -n "$MATCHES" ]; then
    echo "BLOCKED: AI attribution detected in commit message."
    echo ""
    echo "Matched lines:"
    echo "$MATCHES"
    echo ""
    echo "Remove AI attribution from your commit message."
    exit 1
fi

exit 0
